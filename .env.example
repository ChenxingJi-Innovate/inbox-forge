# Copy this file to .env and fill in real values:  cp .env.example .env

# ─── Gemini (required) ───────────────────────────────────────────────────
# From https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Token encryption / OAuth state signing (required) ───────────────────
# Encrypts stored OAuth refresh tokens at rest AND signs the OAuth state.
# Generate one with:
#   openssl rand -base64 32
# (any random string works; longer is better)
TOKEN_ENC_KEY=

# ─── App base URL (required) ─────────────────────────────────────────────
# Used to build the OAuth redirect URIs that get sent to Google / Microsoft.
# Must EXACTLY match (protocol + host, no trailing slash) what you registered
# as the Authorized redirect URI in the OAuth console.
#   Local:  http://127.0.0.1:8000
#   Vercel: https://your-project.vercel.app
APP_BASE_URL=http://127.0.0.1:8000

# ─── Google OAuth (required for Gmail inbox) ─────────────────────────────
# From https://console.cloud.google.com → APIs & Services → Credentials
# Add this as an Authorized redirect URI in the Google OAuth client:
#   <APP_BASE_URL>/api/auth/google/callback
# Enable the Gmail API on this project.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Microsoft OAuth (optional, for Outlook inbox) ───────────────────────
# From https://entra.microsoft.com → App registrations
# Add this as an Authorized redirect URI in the Azure app:
#   <APP_BASE_URL>/api/auth/microsoft/callback
# Delegated permission: Mail.Read
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── Database ────────────────────────────────────────────────────────────
# Local: leave both unset. Uses ~/.inbox-forge/data.db automatically.
# Vercel / cloud: get these from https://turso.tech
#   turso db create inbox-forge
#   turso db show inbox-forge --url
#   turso db tokens create inbox-forge
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional: override local SQLite path (only if TURSO_* are unset)
# DB_PATH=~/.inbox-forge/data.db
