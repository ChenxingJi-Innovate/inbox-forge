# Copy this file to .env and fill in your real values
# (cp .env.example .env)

# Google Gemini API key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=AQ.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Random long string for signing session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-me-with-a-long-random-string

# Set to "true" in production (HTTPS) so cookies are sent only over HTTPS
COOKIE_SECURE=false

# Where SQLite + per-user xlsx files live. On Render this should point to a
# persistent disk mount, e.g. /var/data
DATA_DIR=./data
